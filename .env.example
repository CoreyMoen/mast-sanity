# Sanity API token with write permissions — required for seed scripts
# Create one at: https://www.sanity.io/manage/project/<your-project-id>/api#tokens
SANITY_API_TOKEN="your-write-token-here"
SANITY_API_READ_TOKEN="your-read-token-here" # Required - The read token for your Sanity project

NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id" # Required - The ID of your Sanity project
NEXT_PUBLIC_SANITY_DATASET="production" # Required - The dataset of your Sanity project
NEXT_PUBLIC_SANITY_API_VERSION="2025-09-25" # Optional - The API version provided to the Sanity Client
NEXT_PUBLIC_SANITY_STUDIO_URL="" #Optional, defaults to http://localhost:3334

SANITY_STUDIO_PROJECT_ID="your-project-id" # Required - The ID of your Sanity project
SANITY_STUDIO_DATASET="production" # Required - The dataset of your Sanity project
SANITY_STUDIO_PREVIEW_URL="" #Optional - defaults to http://localhost:3001
SANITY_STUDIO_STUDIO_HOST="" #Optional

ANTHROPIC_API_KEY="your-anthropic-key"  # Optional — enables Claude assistant