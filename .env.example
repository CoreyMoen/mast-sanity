# =============================================================================
# Angela — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# Required variables are marked with (required). Others are optional.

# ─── Clerk Authentication ────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...   # (required)
CLERK_SECRET_KEY=sk_test_...                     # (required)
CLERK_WEBHOOK_SECRET=whsec_...                   # (required) Clerk webhook signing secret

# ─── Convex Backend ──────────────────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud  # (required)
CONVEX_DEPLOY_KEY=                                         # (required for deploy)

# ─── Stripe Payments ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...                    # (required)
STRIPE_WEBHOOK_SECRET=whsec_...                  # (required) Stripe webhook signing secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...   # (required)

# Stripe price IDs for subscription tiers
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_BUSINESS_MONTHLY_PRICE_ID=price_...
STRIPE_BUSINESS_YEARLY_PRICE_ID=price_...

# ─── Payment Provider ────────────────────────────────────────────────────────
# Which payment provider to use: "stripe" (default) or "converge"
PAYMENT_PROVIDER=stripe

# Converge (alternative payment provider — only needed if PAYMENT_PROVIDER=converge)
# NEXT_PUBLIC_CONVERGE_PUBLIC_KEY=
# CONVERGE_PRO_MONTHLY_PRICE_ID=
# CONVERGE_PRO_YEARLY_PRICE_ID=
# CONVERGE_BUSINESS_MONTHLY_PRICE_ID=
# CONVERGE_BUSINESS_YEARLY_PRICE_ID=

# ─── Social Platform OAuth ───────────────────────────────────────────────────
# Meta (Instagram & Facebook)
META_APP_ID=                  # (required) Meta Developer App ID
META_APP_SECRET=              # (required) Meta Developer App Secret

# X / Twitter
TWITTER_CLIENT_ID=            # (required) Twitter OAuth 2.0 Client ID
TWITTER_CLIENT_SECRET=        # (required) Twitter OAuth 2.0 Client Secret

# LinkedIn
LINKEDIN_CLIENT_ID=           # (required) LinkedIn App Client ID
LINKEDIN_CLIENT_SECRET=       # (required) LinkedIn App Client Secret

# ─── Encryption ──────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM (used to encrypt stored OAuth tokens)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=               # (required)

# ─── LLM Providers (at least one required for AI features) ───────────────────
# Google Gemini (default)
GEMINI_API_KEY=

# OpenAI (optional)
OPENAI_API_KEY=

# Anthropic (optional)
ANTHROPIC_API_KEY=

# ─── Build / Development ─────────────────────────────────────────────────────
# Set to "true" to enable @next/bundle-analyzer
# ANALYZE=true
