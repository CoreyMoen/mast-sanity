{
  "name": "mast-sanity",
  "description": "Mast Component Framework for Sanity + Next.js with AI-powered content creation",
  "author": "Corey Moen",
  "license": "MIT",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "studio",
    "frontend"
  ],
  "keywords": [
    "Sanity",
    "Next.js",
    "Headless CMS",
    "Visual Editing",
    "Page Builder",
    "Mast",
    "Claude AI"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CoreyMoen/mast-sanity.git"
  },
  "homepage": "https://github.com/CoreyMoen/mast-sanity#readme",
  "bugs": {
    "url": "https://github.com/CoreyMoen/mast-sanity/issues"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:docker": "docker compose up",
    "format": "prettier --cache --write .",
    "import-sample-data": "cd studio && sanity dataset import sample-data.tar.gz --replace",
    "lint": "npm run lint --workspace=frontend",
    "seed": "node --env-file=.env scripts/seed-starter.mjs",
    "type-check": "turbo run type-check"
  },
  "prettier": "@sanity/prettier-config",
  "overrides": {
    "@sanity/types": "5.9.0"
  },
  "devDependencies": {
    "@sanity/client": "^7.14.1",
    "@sanity/prettier-config": "^2.0.2",
    "prettier": "^3.7.3"
  },
  "dependencies": {
    "turbo": "^2.8.16"
  }
}
